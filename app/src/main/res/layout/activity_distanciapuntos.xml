<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".DistanciaPuntos.distanciapuntos">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cálculo de Distancia entre 2 Puntos"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/edtX1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="X1"
        android:inputType="numberSigned|numberDecimal"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/edtY1" />

    <EditText
        android:id="@+id/edtY1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Y1"
        android:inputType="numberSigned|numberDecimal"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/edtX1"
        app:layout_constraintStart_toEndOf="@id/edtX1"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/edtX2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="X2"
        android:inputType="numberSigned|numberDecimal"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/edtX1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/edtY2" />

    <EditText
        android:id="@+id/edtY2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Y2"
        android:inputType="numberSigned|numberDecimal"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/edtX2"
        app:layout_constraintStart_toEndOf="@id/edtX2"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Calcular Distancia"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/edtX2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado: "
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnCalcular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>